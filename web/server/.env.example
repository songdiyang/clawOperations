# 服务器配置
PORT=3001

# JWT 认证配置
JWT_SECRET=your-secure-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=clawops
DB_PASS=ClawOps@2024!
DB_NAME=clawops

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379

# 抖音开放平台配置 (必须配置才能使用抖音登录)
# 获取地址: https://open.douyin.com
DOUYIN_CLIENT_KEY=your_douyin_client_key
DOUYIN_CLIENT_SECRET=your_douyin_client_secret
DOUYIN_REDIRECT_URI=http://localhost:5173

# DeepSeek AI 配置
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 豆包 AI 配置 (火山引擎方舟大模型)
# 获取地址: https://console.volcengine.com/ark
DOUBAO_API_KEY=your_volcengine_api_key
DOUBAO_ENDPOINT_ID_IMAGE=your_image_endpoint_id
DOUBAO_ENDPOINT_ID_VIDEO=your_video_endpoint_id
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
