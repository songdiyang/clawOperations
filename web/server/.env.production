# ========================================
# ClawOperations 生产环境配置
# 服务器: 101.133.162.255
# ========================================

# 服务器配置
PORT=3001
NODE_ENV=production

# JWT 认证配置 (请修改为强密码)
JWT_SECRET=ClawOps_Prod_Secret_2024_Change_This_To_Your_Own_Key
JWT_EXPIRES_IN=7d

# 抖音开放平台配置
# 获取地址: https://open.douyin.com
# 注意: REDIRECT_URI 需要在抖音开放平台配置为下面的地址
DOUYIN_CLIENT_KEY=your_douyin_client_key
DOUYIN_CLIENT_SECRET=your_douyin_client_secret
DOUYIN_REDIRECT_URI=http://101.133.162.255/auth/callback

# DeepSeek AI 配置
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 豆包 AI 配置 (火山引擎方舟大模型)
DOUBAO_API_KEY=your_volcengine_api_key
DOUBAO_ENDPOINT_ID_IMAGE=your_image_endpoint_id
DOUBAO_ENDPOINT_ID_VIDEO=your_video_endpoint_id
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 日志配置
LOG_LEVEL=info
