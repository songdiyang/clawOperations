# 抖音开放平台配置
DOUYIN_CLIENT_KEY=your_client_key
DOUYIN_CLIENT_SECRET=your_client_secret
DOUYIN_REDIRECT_URI=your_redirect_uri

# 认证凭证（通过 OAuth2.0 流程获取）
DOUYIN_ACCESS_TOKEN=your_access_token
DOUYIN_REFRESH_TOKEN=your_refresh_token
DOUYIN_OPEN_ID=your_open_id

# 应用配置
LOG_LEVEL=info
CHUNK_SIZE_MB=5
MAX_RETRY_COUNT=3
